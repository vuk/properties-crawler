{
    "compilerOptions": {
        "baseUrl": "./src",
        "module": "commonjs",
        "moduleResolution": "node",
        "declaration": false,
        "noImplicitAny": false,
        "noUnusedLocals": false,
        "removeComments": false,
        "noLib": false,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "target": "ES2022",
        "sourceMap": true,
        "allowJs": true,
        "lib": [
            "ES2022"
        ],
        "resolveJsonModule": true,
        "outDir": "./dist",
        "skipLibCheck": true
    },
    "include": [
        "src/**/*",
        "__tests__/*"
    ],
    "exclude": [
        "mocks",
        "node_modules",
        "**/*.spec.ts",
        "**/*.test.ts"
    ]
}
